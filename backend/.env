# Varias variables de entorno para una aplicación Flask que utiliza una base de datos MySQL.

# ===== ENTORNO =====
FLASK_ENV=development
FLASK_DEBUG=True

# ===== APP =====
SECRET_KEY=arsa2025

# ===== SERVER =====
HOST=0.0.0.0 # hace que la aplicación sea accesible desde cualquier dirección IP
PORT=5000

# ===== DATABASE =====
DB_USER=user_dev
DB_PASSWORD=inventario_dev
DB_HOST=localhost
# DB_NAME=sistema_explotacion -- base de datos sin modificar, con tablas antiguas
DB_NAME=explotacion_exploracion_dev
DB_PORT=3306

# ===== JWT =====
JWT_SECRET_KEY=jwt-super-secret
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=86400

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173


# ===== Limitador Request ======
DIA="100000 per day" #limita por dia tiene que string
HORA="10000 per hour"
MINUTOS="1000 per minute"
SEGUNDOS="500 per second"